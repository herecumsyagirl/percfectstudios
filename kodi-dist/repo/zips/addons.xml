<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.percfectstudios"
       name="PercfectStudios"
       version="1.2.0"
       provider-name="PercfectAI">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="addon.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Percfect App — free images + 480p video on TV</summary>
    <description lang="en_GB">Opens percfectai.com/app on your Fire Stick. Free Perchance image batches + 480p xAI video animation. No folder menus — app-style grid UI.</description>
    <platform>all</platform>
    <language>en</language>
  </extension>
</addon>
</addons>
