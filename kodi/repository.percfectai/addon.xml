<?xml version="1.0" encoding="UTF-8"?>
<addon id="repository.percfectai" name="PercfectAI Repository" version="1.0.0" provider-name="PercfectAI">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="PercfectAI Repository">
    <dir minversion="19.0.0">
      <info compressed="false">https://percfectai.com/kodi/repo/zips/addons.xml</info>
      <checksum>https://percfectai.com/kodi/repo/zips/addons.xml.md5</checksum>
      <datadir zip="true">https://percfectai.com/kodi/repo/zips/</datadir>
      <hashes>false</hashes>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">PercfectAI unofficial add-on repository</summary>
    <description lang="en_GB">Repository for PercfectStudios — AI image and video generation on Fire Stick and Kodi.</description>
    <platform>all</platform>
    <language>en</language>
  </extension>
</addon>
