<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.percfectstudios"
       name="PercfectStudios"
       version="1.3.1"
       provider-name="PercfectAI">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="addon.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Perchance + fal images, 480p video on TV</summary>
    <description lang="en_GB">Two image modes: PERCHANCE (free generator) and FAL (FLUX Schnell batch of 10 with princess presets). Shared My Percfect Pics and 480p xAI video. Install via Downloader percfectai.com/k</description>
    <platform>all</platform>
    <language>en</language>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>resources/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
</addons>
